# API URL for the Julia MILP server
# Copy this file to .env and fill in your actual ngrok tunnel URL.
#
# After starting the server (julia milp_server.jl) and running ngrok (ngrok http 8080),
# update line 752 of index.html with your tunnel URL:
#
#   const API_BASE = 'https://your-tunnel-id.ngrok-free.app';
#
API_URL=https://your-tunnel-id.ngrok-free.app
